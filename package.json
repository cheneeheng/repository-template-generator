{
  "scripts": {
    "dev": "concurrently \"bun run dev --prefix server\" \"bun run dev --prefix client\"",
    "test": "concurrently \"bun run test --prefix server\" \"bun run test --prefix client\"",
    "docker:up": "docker compose -f deployment/docker-compose.yml up --build",
    "docker:down": "docker compose -f deployment/docker-compose.yml down",
    "docker:dev": "docker compose -f deployment/docker-compose.yml -f deployment/docker-compose.dev.yml up --build",
    "eval": "bun scripts/eval.js",
    "eval:v2": "EVAL_PROMPT_VERSION=v2 bun scripts/eval.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}